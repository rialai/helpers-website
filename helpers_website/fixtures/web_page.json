  "main_section_html": "<style>\n@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');\n:root { --bg: #0f0f0f; --text: #f5f5f5; --muted: #9ea0a3; --card: #171717; --accent: #d1d5db; }\n* { box-sizing: border-box; }\nbody { background: var(--bg); color: var(--text); font-family: 'Space Grotesk', sans-serif !important; }\ncanvas#bg-graph { position: fixed; inset: 0; width: 100vw; height: 100vh; z-index: -1; background: radial-gradient(circle at 20% 20%, #131313, #0b0b0b 40%, #050505 80%); opacity: 0.8; pointer-events: none; }\n.page-wrap { position: relative; max-width: 1080px; margin: 0 auto; padding: 56px 20px 88px; }\n.badge { display: inline-flex; align-items: center; gap: 8px; border: 1px solid #1f1f1f; background: var(--card); color: var(--muted); border-radius: 999px; padding: 6px 12px; font-size: 13px; letter-spacing: 0.4px; text-transform: uppercase; }\n.grid { display: grid; gap: 18px; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); margin-top: 24px; }\n.card { background: var(--card); border: 1px solid #1f1f1f; border-radius: 16px; padding: 18px 18px 16px; }\n.card h3 { margin: 0 0 6px; font-size: 18px; color: var(--text); }\n.card p { margin: 0; color: var(--muted); line-height: 1.5; font-size: 14px; }\n.hero { display: flex; flex-direction: column; gap: 18px; margin: 36px 0 18px; }\n.hero h1 { font-size: clamp(32px, 6vw, 56px); margin: 0; letter-spacing: -0.6px; }\n.hero p { margin: 0; color: var(--muted); line-height: 1.6; font-size: 16px; max-width: 720px; }\n.section-title { margin: 42px 0 12px; font-size: 16px; letter-spacing: 0.6px; text-transform: uppercase; color: var(--muted); }\n.pill { display: flex; align-items: flex-start; gap: 12px; padding: 12px 0; border-bottom: 1px solid #1f1f1f; }\n.pill:last-child { border-bottom: none; }\n.pill strong { color: var(--text); font-size: 15px; }\n.pill span { color: var(--muted); font-size: 14px; line-height: 1.5; }\n.cta-row { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; }\n.button { display: inline-flex; align-items: center; gap: 8px; padding: 12px 16px; border-radius: 12px; border: 1px solid #ffffff22; color: var(--text); background: linear-gradient(120deg, #1f1f1f, #111); text-decoration: none; font-weight: 600; box-shadow: 0 10px 35px #00000044; transition: transform 120ms ease, border-color 120ms ease; }\n.button:hover { transform: translateY(-1px); border-color: #ffffff44; }\n.muted-link { color: var(--muted); text-decoration: none; border-bottom: 1px solid #ffffff14; padding-bottom: 2px; }\n.muted-link:hover { color: var(--text); border-color: #ffffff33; }\n.footer { margin-top: 48px; color: var(--muted); font-size: 13px; display: flex; gap: 12px; flex-wrap: wrap; }\n</style>\n<canvas id=\"bg-graph\"></canvas>\n<div class=\"page-wrap\">\n  <div class=\"badge\">Helpers.ie / Collective Co-op</div>\n  <div class=\"hero\">\n    <h1>Engineering collective for teams that build and ship.</h1>\n    <p>We connect experts, process, and tooling. From infra audits to getting product live — without bureaucracy or extra management layers.</p>\n    <div class=\"cta-row\">\n      <a class=\"button\" href=\"#contact\">Contact</a>\n      <a class=\"muted-link\" href=\"#approach\">How we work</a>\n    </div>\n  </div>\n  <div id=\"approach\" class=\"section-title\">Approach</div>\n  <div class=\"grid\">\n    <div class=\"card\">\n      <h3>Collective first</h3>\n      <p>We operate as a co-op: bring the right experts per task, share upside, keep quality.</p>\n    </div>\n    <div class=\"card\">\n      <h3>Lean delivery</h3>\n      <p>Short iterations, metrics, observability. Prove value in 2-4 weeks.</p>\n    </div>\n    <div class=\"card\">\n      <h3>Transparent ops</h3>\n      <p>Process so your team can run without us: documentation, access, quality gates.</p>\n    </div>\n  </div>\n  <div style=\"position: relative; width: 100%; height: 400px; border-bottom: 1px solid #1f1f1f; margin: 60px 0; background: linear-gradient(180deg, #0f0f0f, #1a1a1a); border-radius: 12px; overflow: hidden;\">\n    <canvas id=\"resources-graph-canvas\" style=\"display: block; width: 100%; height: 100%;\"></canvas>\n    <div style=\"position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: center; align-items: center; background: rgba(0, 0, 0, 0.3); pointer-events: none; color: #9ea0a3;\">\n      <div style=\"font-size: 14px; letter-spacing: 0.6px; text-transform: uppercase; margin-bottom: 8px;\">Enterprise Resources</div>\n      <div style=\"font-size: 24px; font-weight: 600; color: #f5f5f5;\" id=\"resources-count\">Loading...</div>\n    </div>\n  </div>\n  <div class=\"section-title\">What we do</div>\n  <div class=\"pill\">\n    <strong>Infrastructure</strong><span>Audits, cost-cutting, IaC, CI/CD, observability.</span>\n  </div>\n  <div class=\"pill\">\n    <strong>Product</strong><span>Discovery, design, delivery — standalone or embedded with your team.</span>\n  </div>\n  <div class=\"pill\">\n    <strong>Security</strong><span>Secure SDLC, access, secrets, deployment policies.</span>\n  </div>\n  <div class=\"pill\">\n    <strong>Operations</strong><span>SLO/SLI, on-call, incident response.</span>\n  </div>\n  <div id=\"contact\" class=\"section-title\">Contact</div>\n  <div class=\"grid\">\n    <div class=\"card\">\n      <h3>Reach out</h3>\n      <p>Email contact@helpers.ie or drop your brief. We respond within a business day.</p>\n    </div>\n    <div class=\"card\">\n      <h3>Engagement</h3>\n      <p>Retainer or fixed-scope. Start with a short audit and a 2-4 week plan.</p>\n    </div>\n  </div>\n  <div class=\"footer\">\n    <span>helpers.ie</span><span>/</span><span>Collective Co-op</span>\n  </div>\n</div>\n<script>\n(() => {\n  const canvas = document.getElementById('bg-graph');\n  const ctx = canvas.getContext('2d');\n  let w = 0;\n  let h = 0;\n  const nodes = [];\n  const count = 48;\n  const maxDist = 240;\n  const pulseSpeed = 0.003;\n  const resize = () => {\n    w = canvas.width = window.innerWidth;\n    h = canvas.height = window.innerHeight;\n  };\n  const rand = (min, max) => Math.random() * (max - min) + min;\n  const init = () => {\n    nodes.length = 0;\n    for (let i = 0; i < count; i++) {\n      nodes.push({\n        x: rand(0, w),\n        y: rand(0, h),\n        vx: rand(-0.45, 0.45),\n        vy: rand(-0.45, 0.45),\n        base: rand(2.4, 4.2),\n        phase: Math.random() * Math.PI * 2\n      });\n    }\n  };\n  const step = (t) => {\n    ctx.clearRect(0, 0, w, h);\n    ctx.fillStyle = 'rgba(10,10,10,0.35)';\n    ctx.fillRect(0, 0, w, h);\n    const degree = new Array(nodes.length).fill(0);\n    for (let i = 0; i < nodes.length; i++) {\n      for (let j = i + 1; j < nodes.length; j++) {\n        const dx = nodes[i].x - nodes[j].x;\n        const dy = nodes[i].y - nodes[j].y;\n        const d2 = dx * dx + dy * dy;\n        if (d2 < maxDist * maxDist) {\n          const alpha = 1 - Math.sqrt(d2) / maxDist;\n          ctx.strokeStyle = `rgba(200, 200, 200, ${alpha * 0.35})`;\n          ctx.lineWidth = 1;\n          ctx.beginPath();\n          ctx.moveTo(nodes[i].x, nodes[i].y);\n          ctx.lineTo(nodes[j].x, nodes[j].y);\n          ctx.stroke();\n          degree[i] += 1;\n          degree[j] += 1;\n        }\n      }\n    }\n    for (let idx = 0; idx < nodes.length; idx++) {\n      const n = nodes[idx];\n      n.x += n.vx;\n      n.y += n.vy;\n      if (n.x < 0 || n.x > w) n.vx *= -1;\n      if (n.y < 0 || n.y > h) n.vy *= -1;\n      const r = n.base + Math.sin(t * pulseSpeed + n.phase) * 1.2 + degree[idx] * 0.6;\n      const g = 210;\n      ctx.beginPath();\n      ctx.fillStyle = `rgba(${g}, ${g}, ${g}, 0.85)`;\n      ctx.shadowColor = 'rgba(255,255,255,0.15)';\n      ctx.shadowBlur = 8;\n      ctx.arc(n.x, n.y, r, 0, Math.PI * 2);\n      ctx.fill();\n      ctx.shadowBlur = 0;\n    }\n    requestAnimationFrame(step);\n  };\n  window.addEventListener('resize', () => { resize(); init(); });\n  resize();\n  init();\n  requestAnimationFrame(step);\n})();\n</script>\n<script src=\"/assets/helpers_website/js/resources-graph.js\"></script>\n<script>\n(function() {\n  let checkCount = 0;\n  const checkInterval = setInterval(() => {\n    if (window.ResourcesGraph && window.ResourcesGraph.nodes.length > 0) {\n      document.getElementById('resources-count').textContent = \n        window.ResourcesGraph.nodes.length + ' Resources';\n      clearInterval(checkInterval);\n    }\n    checkCount++;\n    if (checkCount > 50) clearInterval(checkInterval);\n  }, 100);\n})();\n</script>",
